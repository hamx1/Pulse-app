import React, { useEffect, useState } from 'react';
import {
  View,
  Text,
  StyleSheet,
  ScrollView,
  ActivityIndicator,
  TouchableOpacity,
  RefreshControl,
} from 'react-native';
import { LinearGradient } from 'expo-linear-gradient';
import { Ionicons, MaterialCommunityIcons } from '@expo/vector-icons';
import { api } from '@/src/utils/api';
import { DashboardData } from '@/src/types';
import { SafeAreaView } from 'react-native-safe-area-context';

export default function DashboardScreen() {
  const [dashboardData, setDashboardData] = useState<DashboardData | null>(null);
  const [loading, setLoading] = useState(true);
  const [refreshing, setRefreshing] = useState(false);

  const loadDashboard = async () => {
    try {
      const data = await api.getDashboard();
      setDashboardData(data);
    } catch (error) {
      console.error('Failed to load dashboard:', error);
    } finally {
      setLoading(false);
      setRefreshing(false);
    }
  };

  const onRefresh = () => {
    setRefreshing(true);
    loadDashboard();
  };

  useEffect(() => {
    loadDashboard();
  }, []);

  if (loading) {
    return (
      <View style={styles.loadingContainer}>
        <ActivityIndicator size="large" color="#00FF88" />
      </View>
    );
  }

  const studyProgress = dashboardData
    ? (dashboardData.study.total_minutes / dashboardData.study.goal_minutes) * 100
    : 0;

  const nutritionProgress = dashboardData
    ? (dashboardData.nutrition.total_calories / dashboardData.nutrition.goal_calories) * 100
    : 0;

  return (
    <SafeAreaView style={styles.container} edges={['top']}>
      <ScrollView
        style={styles.scrollView}
        contentContainerStyle={styles.scrollContent}
        refreshControl={
          <RefreshControl
            refreshing={refreshing}
            onRefresh={onRefresh}
            tintColor="#00FF88"
            colors={['#00FF88']}
          />
        }
      >
        {/* Header */}
        <View style={styles.header}>
          <View>
            <Text style={styles.greeting}>Welcome Back</Text>\n            <Text style={styles.title}>Your Pulse Today</Text>\n          </View>\n          <LinearGradient\n            colors={['#00FF88', '#00D4FF']}\n            start={{ x: 0, y: 0 }}\n            end={{ x: 1, y: 1 }}\n            style={styles.logoContainer}\n          >\n            <Ionicons name=\"pulse\" size={32} color=\"#0A0A0A\" />\n          </LinearGradient>\n        </View>\n\n        {/* Study Card */}\n        <LinearGradient\n          colors={['#1A1A1A', '#151515']}\n          style={styles.card}\n        >\n          <View style={styles.cardHeader}>\n            <View style={styles.cardTitleRow}>\n              <MaterialCommunityIcons name=\"book-open-outline\" size={24} color=\"#00FF88\" />\n              <Text style={styles.cardTitle}>Study Progress</Text>\n            </View>\n            <Text style={styles.cardValue}>{Math.round(studyProgress)}%</Text>\n          </View>\n          \n          <View style={styles.progressBarContainer}>\n            <View style={styles.progressBarBg}>\n              <LinearGradient\n                colors={['#00FF88', '#00D4FF']}\n                start={{ x: 0, y: 0 }}\n                end={{ x: 1, y: 0 }}\n                style={[styles.progressBarFill, { width: `${Math.min(studyProgress, 100)}%` }]}\n              />\n            </View>\n          </View>\n\n          <View style={styles.statsRow}>\n            <View style={styles.stat}>\n              <Text style={styles.statValue}>\n                {Math.floor((dashboardData?.study.total_minutes || 0) / 60)}h{' '}\n                {(dashboardData?.study.total_minutes || 0) % 60}m\n              </Text>\n              <Text style={styles.statLabel}>Studied</Text>\n            </View>\n            <View style={styles.statDivider} />\n            <View style={styles.stat}>\n              <Text style={styles.statValue}>{dashboardData?.study.sessions_count || 0}</Text>\n              <Text style={styles.statLabel}>Sessions</Text>\n            </View>\n            <View style={styles.statDivider} />\n            <View style={styles.stat}>\n              <Text style={styles.statValue}>\n                {Math.floor((dashboardData?.study.goal_minutes || 0) / 60)}h\n              </Text>\n              <Text style={styles.statLabel}>Goal</Text>\n            </View>\n          </View>\n        </LinearGradient>\n\n        {/* Workout Card */}\n        <LinearGradient\n          colors={['#1A1A1A', '#151515']}\n          style={styles.card}\n        >\n          <View style={styles.cardHeader}>\n            <View style={styles.cardTitleRow}>\n              <MaterialCommunityIcons name=\"dumbbell\" size={24} color=\"#00D4FF\" />\n              <Text style={styles.cardTitle}>Today's Workout</Text>\n            </View>\n            {dashboardData?.workout && (\n              <View style={[styles.intensityBadge, \n                dashboardData.workout.intensity === 'intense' && styles.intensityBadgeIntense,\n                dashboardData.workout.intensity === 'moderate' && styles.intensityBadgeModerate,\n                dashboardData.workout.intensity === 'light' && styles.intensityBadgeLight,\n              ]}>\n                <Text style={styles.intensityText}>\n                  {dashboardData.workout.intensity.toUpperCase()}\n                </Text>\n              </View>\n            )}\n          </View>\n\n          {dashboardData?.workout ? (\n            <>\n              <Text style={styles.workoutDuration}>\n                {dashboardData.workout.duration} minutes\n              </Text>\n              <View style={styles.exercisesList}>\n                {dashboardData.workout.exercises.slice(0, 3).map((exercise, index) => (\n                  <View key={index} style={styles.exerciseItem}>\n                    <View style={styles.exerciseDot} />\n                    <Text style={styles.exerciseName}>{exercise.name}</Text>\n                    <Text style={styles.exerciseDuration}>{exercise.duration}min</Text>\n                  </View>\n                ))}\n              </View>\n              {dashboardData.workout.completed ? (\n                <View style={styles.completedBadge}>\n                  <Ionicons name=\"checkmark-circle\" size={20} color=\"#00FF88\" />\n                  <Text style={styles.completedText}>Completed</Text>\n                </View>\n              ) : (\n                <TouchableOpacity style={styles.startButton}>\n                  <LinearGradient\n                    colors={['#00D4FF', '#0099FF']}\n                    start={{ x: 0, y: 0 }}\n                    end={{ x: 1, y: 0 }}\n                    style={styles.startButtonGradient}\n                  >\n                    <Text style={styles.startButtonText}>Start Workout</Text>\n                    <Ionicons name=\"arrow-forward\" size={20} color=\"#FFFFFF\" />\n                  </LinearGradient>\n                </TouchableOpacity>\n              )}\n            </>\n          ) : (\n            <View style={styles.emptyState}>\n              <MaterialCommunityIcons name=\"yoga\" size={48} color=\"#333333\" />\n              <Text style={styles.emptyText}>No workout generated yet</Text>\n              <Text style={styles.emptySubtext}>Complete a study session first</Text>\n            </View>\n          )}\n        </LinearGradient>\n\n        {/* Nutrition Card */}\n        <LinearGradient\n          colors={['#1A1A1A', '#151515']}\n          style={[styles.card, { marginBottom: 30 }]}\n        >\n          <View style={styles.cardHeader}>\n            <View style={styles.cardTitleRow}>\n              <Ionicons name=\"nutrition\" size={24} color=\"#FF6B6B\" />\n              <Text style={styles.cardTitle}>Nutrition</Text>\n            </View>\n            <Text style={styles.cardValue}>{Math.round(nutritionProgress)}%</Text>\n          </View>\n\n          <View style={styles.progressBarContainer}>\n            <View style={styles.progressBarBg}>\n              <View\n                style={[\n                  styles.progressBarFill,\n                  { width: `${Math.min(nutritionProgress, 100)}%`, backgroundColor: '#FF6B6B' },\n                ]}\n              />\n            </View>\n          </View>\n\n          <View style={styles.statsRow}>\n            <View style={styles.stat}>\n              <Text style={styles.statValue}>\n                {dashboardData?.nutrition.total_calories || 0}\n              </Text>\n              <Text style={styles.statLabel}>Calories</Text>\n            </View>\n            <View style={styles.statDivider} />\n            <View style={styles.stat}>\n              <Text style={styles.statValue}>\n                {dashboardData?.nutrition.total_protein || 0}g\n              </Text>\n              <Text style={styles.statLabel}>Protein</Text>\n            </View>\n            <View style={styles.statDivider} />\n            <View style={styles.stat}>\n              <Text style={styles.statValue}>\n                {dashboardData?.nutrition.meals_count || 0}\n              </Text>\n              <Text style={styles.statLabel}>Meals</Text>\n            </View>\n          </View>\n        </LinearGradient>\n      </ScrollView>\n    </SafeAreaView>\n  );\n}\n\nconst styles = StyleSheet.create({\n  container: { flex: 1, backgroundColor: '#0A0A0A' },\n  loadingContainer: { flex: 1, backgroundColor: '#0A0A0A', justifyContent: 'center', alignItems: 'center' },\n  scrollView: { flex: 1 },\n  scrollContent: { padding: 20 },\n  header: { flexDirection: 'row', justifyContent: 'space-between', alignItems: 'center', marginBottom: 24 },\n  greeting: { fontSize: 14, color: '#A0A0A0', marginBottom: 4 },\n  title: { fontSize: 28, fontWeight: 'bold', color: '#FFFFFF' },\n  logoContainer: { width: 56, height: 56, borderRadius: 28, justifyContent: 'center', alignItems: 'center' },\n  card: { borderRadius: 20, padding: 20, marginBottom: 16, borderWidth: 1, borderColor: '#2A2A2A' },\n  cardHeader: { flexDirection: 'row', justifyContent: 'space-between', alignItems: 'center', marginBottom: 16 },\n  cardTitleRow: { flexDirection: 'row', alignItems: 'center', gap: 12 },\n  cardTitle: { fontSize: 18, fontWeight: '600', color: '#FFFFFF' },\n  cardValue: { fontSize: 24, fontWeight: 'bold', color: '#00FF88' },\n  progressBarContainer: { marginBottom: 20 },\n  progressBarBg: { height: 8, backgroundColor: '#2A2A2A', borderRadius: 4, overflow: 'hidden' },\n  progressBarFill: { height: '100%', borderRadius: 4 },\n  statsRow: { flexDirection: 'row', justifyContent: 'space-around' },\n  stat: { alignItems: 'center', flex: 1 },\n  statValue: { fontSize: 20, fontWeight: 'bold', color: '#FFFFFF', marginBottom: 4 },\n  statLabel: { fontSize: 12, color: '#A0A0A0' },\n  statDivider: { width: 1, backgroundColor: '#2A2A2A', marginHorizontal: 8 },\n  intensityBadge: { paddingHorizontal: 12, paddingVertical: 6, borderRadius: 12 },\n  intensityBadgeIntense: { backgroundColor: 'rgba(255, 59, 48, 0.2)' },\n  intensityBadgeModerate: { backgroundColor: 'rgba(255, 204, 0, 0.2)' },\n  intensityBadgeLight: { backgroundColor: 'rgba(48, 209, 88, 0.2)' },\n  intensityText: { fontSize: 10, fontWeight: 'bold', color: '#FFFFFF' },\n  workoutDuration: { fontSize: 14, color: '#A0A0A0', marginBottom: 16 },\n  exercisesList: { marginBottom: 16 },\n  exerciseItem: { flexDirection: 'row', alignItems: 'center', paddingVertical: 8 },\n  exerciseDot: { width: 6, height: 6, borderRadius: 3, backgroundColor: '#00D4FF', marginRight: 12 },\n  exerciseName: { flex: 1, fontSize: 14, color: '#FFFFFF' },\n  exerciseDuration: { fontSize: 12, color: '#A0A0A0' },\n  completedBadge: { flexDirection: 'row', alignItems: 'center', justifyContent: 'center', gap: 8, paddingVertical: 12, backgroundColor: 'rgba(0, 255, 136, 0.1)', borderRadius: 12 },\n  completedText: { fontSize: 14, fontWeight: '600', color: '#00FF88' },\n  startButton: { borderRadius: 12, overflow: 'hidden' },\n  startButtonGradient: { flexDirection: 'row', alignItems: 'center', justifyContent: 'center', gap: 8, paddingVertical: 14 },\n  startButtonText: { fontSize: 16, fontWeight: '600', color: '#FFFFFF' },\n  emptyState: { alignItems: 'center', paddingVertical: 32 },\n  emptyText: { fontSize: 16, color: '#666666', marginTop: 12 },\n  emptySubtext: { fontSize: 12, color: '#444444', marginTop: 4 },\n});
